{
  "name": "poe2db-lookup",
  "title": "PoE2DB Lookup",
  "description": "Search PoE2DB names across Simplified Chinese, Traditional Chinese, English, and internal values.",
  "icon": "app-icon.png",
  "author": "allonli",
  "license": "MIT",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Productivity",
    "Developer Tools"
  ],
  "commands": [
    {
      "name": "search",
      "title": "Search PoE2DB Names",
      "description": "Search and paste PoE2DB multilingual names or values.",
      "mode": "view"
    },
    {
      "name": "refresh",
      "title": "Refresh PoE2DB Data",
      "description": "Refresh cached PoE2DB autocomplete data.",
      "mode": "no-view"
    }
  ],
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@raycast/api": "^1.102.7",
    "opencc-js": "^1.0.5",
    "pinyin-pro": "^3.27.0",
    "react": "19.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.5.3"
}
