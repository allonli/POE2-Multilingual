<Window x:Class="Poe2DbLookup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Path Of Exile 2 Multilingual"
        Width="874"
        Height="532"
        Icon="Assets/app-icon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated">
  <Window.Resources>
    <SolidColorBrush x:Key="MutedText" Color="#9CA3AF" />
    <SolidColorBrush x:Key="PrimaryText" Color="#F8FAFC" />

    <Style x:Key="ScrollBarLineButtonStyle" TargetType="{x:Type RepeatButton}">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type RepeatButton}">
            <Border Background="Transparent" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="{x:Type Thumb}">
      <Setter Property="Background" Value="#475569" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Thumb}">
            <Border x:Name="ThumbChrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbChrome" Property="Background" Value="#64748B" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
      <Setter Property="Width" Value="10" />
      <Setter Property="Background" Value="#111827" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ScrollBar}">
            <Grid Background="Transparent">
              <Border Background="{TemplateBinding Background}"
                      CornerRadius="5"
                      Opacity="0.72" />
              <Track x:Name="PART_Track"
                     IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                Style="{StaticResource ScrollBarLineButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Background="#475569" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                Style="{StaticResource ScrollBarLineButtonStyle}" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OutputContextMenuStyle" TargetType="{x:Type ContextMenu}">
      <Setter Property="Background" Value="#111827" />
      <Setter Property="BorderBrush" Value="#374151" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ContextMenu}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10"
                    Padding="{TemplateBinding Padding}">
              <StackPanel IsItemsHost="True"
                          KeyboardNavigation.DirectionalNavigation="Cycle" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OutputMenuItemStyle" TargetType="{x:Type MenuItem}">
      <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinWidth" Value="260" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type MenuItem}">
            <Border x:Name="MenuItemChrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    TextElement.Foreground="{TemplateBinding Foreground}">
              <ContentPresenter ContentSource="Header"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="MenuItemChrome" Property="Background" Value="#2F6FED" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SettingsIconButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#1E293B" />
      <Setter Property="BorderBrush" Value="#475569" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#CBD5E1" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#263449" />
                <Setter Property="Foreground" Value="#F8FAFC" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ResultItemStyle" TargetType="{x:Type ListViewItem}">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="MinHeight" Value="61" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ListViewItem}">
            <Border x:Name="Row"
                    Background="{TemplateBinding Background}"
                    CornerRadius="11"
                    Padding="13,8"
                    SnapsToDevicePixels="True">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Row" Property="Background" Value="#203047" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Row" Property="Background" Value="#2F6FED" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Border Margin="23"
            CornerRadius="23"
            BorderBrush="#334155"
            BorderThickness="1"
            Background="#F0141824">
      <Border.Effect>
        <DropShadowEffect BlurRadius="36" ShadowDepth="11" Opacity="0.45" Color="#000000" />
      </Border.Effect>
      <Grid Margin="21">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,13"
                CornerRadius="17"
                Background="#111827"
                BorderBrush="#374151"
                BorderThickness="1"
                Padding="15,9">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#x2315;"
                       Foreground="#93C5FD"
                       FontSize="26"
                       VerticalAlignment="Center"
                       Margin="0,0,11,2" />
            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{StaticResource PrimaryText}"
                     CaretBrush="#93C5FD"
                     FontSize="27"
                     FontWeight="Medium"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged" />
          </Grid>
        </Border>

        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="{StaticResource PrimaryText}"
                  ItemContainerStyle="{StaticResource ResultItemStyle}"
                  MouseDoubleClick="ResultsList_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="1.15*" />
                  <ColumnDefinition Width="1.15*" />
                  <ColumnDefinition Width="1.05*" />
                  <ColumnDefinition Width="0.7*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding CnLabel}" ToolTip="{Binding CnLabel}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding TwLabel}" ToolTip="{Binding TwLabel}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="11,0,0,0" />
                <TextBlock Grid.Column="2" Text="{Binding UsLabel}" ToolTip="{Binding UsLabel}" FontSize="14" TextTrimming="CharacterEllipsis" Margin="11,0,0,0" />
                <TextBlock Grid.Column="3" Text="{Binding Type}" ToolTip="{Binding Type}" Foreground="#BFDBFE" FontSize="12" TextTrimming="CharacterEllipsis" Margin="11,2,0,0" HorizontalAlignment="Right" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2"
              Margin="2,11,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="StatusText"
                     Text="&#x6B63;&#x5728;&#x51C6;&#x5907;&#x6570;&#x636E;..."
                     Foreground="{StaticResource MutedText}"
                     FontSize="11"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     Margin="0,0,12,0" />
          <Button x:Name="SettingsButton"
                  Grid.Column="1"
                  ToolTip="设置"
                  Click="SettingsButton_Click"
                  Style="{StaticResource SettingsIconButtonStyle}">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE713;"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
          </Button>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
